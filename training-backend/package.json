{
  "name": "coach-train-backend",
  "version": "0.1.0",
  "description": "Backend API for football training app",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n tsc,node -c yellow,magenta \"tsc --watch\" \"wait-on dist/server.js && node --watch dist/server.js\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "supabase": "^2.39.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^8.2.2",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  }
}
